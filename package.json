{
  "name": "react-native-image-compression-kit",
  "version": "0.4.0",
  "description": "Native-first image compression and transcoding pipeline for React Native.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GGULBAE/react-native-image-compression-kit.git"
  },
  "bugs": {
    "url": "https://github.com/GGULBAE/react-native-image-compression-kit/issues"
  },
  "homepage": "https://ggulbae.github.io/react-native-image-compression-kit/",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "android/build.gradle",
    "android/src/main",
    "ios",
    "lib",
    "src",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "LICENSE",
    "react-native-image-compression-kit.podspec",
    "react-native.config.js"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "example:android": "pnpm --filter image-compression-kit-example android",
    "example:build": "RNICK_ANDROID_APP_DIR=example/android pnpm android:build",
    "example:codegen": "RNICK_ANDROID_APP_DIR=example/android pnpm android:codegen",
    "example:android-instrumentation": "RNICK_ANDROID_APP_DIR=example/android RNICK_ANDROID_GRADLE_TASK=:react-native-image-compression-kit:connectedDebugAndroidTest pnpm android:build",
    "example:android-unit-test": "RNICK_ANDROID_APP_DIR=example/android RNICK_ANDROID_GRADLE_TASK=:react-native-image-compression-kit:testDebugUnitTest pnpm android:build",
    "example:ios": "pnpm --filter image-compression-kit-example ios",
    "example:ios:pods": "node scripts/ios-validation.mjs pods",
    "example:ios:build": "node scripts/ios-validation.mjs build",
    "example:ios:decoder-test": "node scripts/ios-validation.mjs decoder-test",
    "example:ios:encoder-test": "node scripts/ios-validation.mjs encoder-test",
    "example:ios:output-test": "node scripts/ios-validation.mjs output-test",
    "example:ios:pipeline-test": "node scripts/ios-validation.mjs pipeline-test",
    "example:ios:large-image-test": "node scripts/ios-validation.mjs large-image-test",
    "example:ios:metadata-test": "node scripts/ios-validation.mjs metadata-test",
    "example:ios:transformer-test": "node scripts/ios-validation.mjs transformer-test",
    "example:ios:input-test": "node scripts/ios-validation.mjs input-test",
    "example:ios:request-parser-test": "node scripts/ios-validation.mjs request-parser-test",
    "example:ios:request-test": "node scripts/ios-validation.mjs request-parser-test",
    "example:ios:smoke": "node scripts/ios-validation.mjs smoke",
    "example:start": "pnpm --filter image-compression-kit-example start",
    "example:typecheck": "pnpm --filter image-compression-kit-example typecheck",
    "fixtures:avif": "node scripts/generate-avif-fixtures.mjs",
    "fixtures:avif:check": "node scripts/generate-avif-fixtures.mjs --check",
    "fixtures:heic-heif": "node scripts/generate-heic-heif-fixtures.mjs",
    "fixtures:heic-heif:check": "node scripts/generate-heic-heif-fixtures.mjs --check",
    "fixtures:ios-pass-replay": "node scripts/refresh-ios-smoke-pass-replay.mjs",
    "fixtures:ios-pass-replay:check": "node scripts/refresh-ios-smoke-pass-replay.mjs --check",
