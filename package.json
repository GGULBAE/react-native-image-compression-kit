    "hooks:install": "node scripts/install-git-hooks.mjs",
    "docs:check": "node scripts/verify-docs.mjs",
    "site:dev": "vitepress dev website",
    "site:build": "vitepress build website",
    "site:preview": "vitepress preview website",
    "site:check": "node scripts/verify-site.mjs",
    "site:quality": "node scripts/verify-site-quality.mjs",
    "verify:demo-evidence": "node scripts/verify-demo-evidence.mjs",
    "merge:demo-evidence": "node scripts/merge-demo-evidence.mjs",
    "release:dry-run": "node scripts/release-dry-run.mjs",
    "smoke:consumer": "pnpm build && node scripts/consumer-smoke-test.mjs",
    "smoke:registry": "node scripts/registry-smoke-test.mjs",
    "verify:registry-health": "node scripts/verify-registry-health.mjs",
    "verify:registry-provenance": "node scripts/verify-registry-provenance.mjs",
    "verify:registry-attestation": "node scripts/verify-registry-attestation.mjs",
    "verify:release-evidence": "node scripts/verify-release-evidence.mjs",
    "import:release-evidence": "node scripts/import-release-evidence.mjs",
    "acquire:release-evidence": "node scripts/acquire-release-evidence.mjs",
    "acquire:release-evidence-review": "node scripts/acquire-release-evidence-review.mjs",
    "fixtures:release-evidence-review-acquisition:check": "node scripts/check-release-evidence-review-acquisition-fixture.mjs",
    "fixtures:compatibility:check": "node scripts/verify-compatibility-matrix.mjs",
    "fixtures:repository-settings:check": "node scripts/verify-repository-settings-contract.mjs",
    "compatibility:consumer": "node scripts/compatibility-consumer.mjs",
    "audit:repository-settings": "node scripts/audit-repository-settings.mjs",
    "prepare:release-evidence-policy": "node scripts/prepare-release-evidence-policy.mjs",
    "promote:release-evidence-policy": "node scripts/promote-release-evidence-policy.mjs",
    "review:release-evidence-policy": "node scripts/review-release-evidence-policy.mjs",
    "verify:release-evidence-review": "node scripts/verify-release-evidence-review.mjs",
    "verify:release-evidence-review-attestation": "node scripts/verify-release-evidence-review-attestation.mjs",
    "import:release-evidence-review": "node scripts/import-release-evidence-review-archive.mjs",
    "verify:release-evidence-review-archive": "node scripts/verify-release-evidence-review-archive.mjs",
    "verify:release-evidence-review-archive-set": "node scripts/verify-release-evidence-review-archive-set.mjs",
    "verify:release-evidence-set": "node scripts/verify-release-evidence-set.mjs",
    "verify:dependency-security": "node scripts/verify-dependency-security.mjs",
    "verify:workflow-supply-chain": "node scripts/verify-workflow-supply-chain.mjs",
    "verify:release-artifact": "node scripts/verify-release-artifact.mjs",
    "verify:release-source": "node scripts/verify-release-source.mjs",
    "verify:publication-state": "node scripts/verify-publication-state.mjs",
    "review:action-pin": "node scripts/review-action-pin.mjs",
    "verify:action-pin-provenance": "node scripts/verify-action-pin-provenance.mjs",
    "verify:action-pin-attestation": "node scripts/verify-action-pin-attestation.mjs",
    "verify:action-pin-fixture": "pnpm verify:action-pin-provenance -- --artifact-dir test/fixtures/action-pin-review --json",
    "verify:action-pin-attestation-fixture": "pnpm verify:action-pin-attestation -- --artifact-dir test/fixtures/action-pin-review --attestation-bundle test/fixtures/action-pin-attestation/attestation.jsonl --trusted-root test/fixtures/action-pin-attestation/trusted-root.jsonl --json",
    "verify": "pnpm typecheck && pnpm test:coverage && pnpm build && pnpm docs:check && pnpm site:check && pnpm fixtures:compatibility:check && pnpm fixtures:ios-pass-replay:audit && pnpm fixtures:release-evidence-acquisition:check && pnpm fixtures:release-evidence-review-acquisition:check && pnpm verify:release-evidence-set -- --json && pnpm verify:release-evidence-review-archive-set -- --json && pnpm verify:dependency-security -- --json && pnpm verify:workflow-supply-chain -- --json && pnpm verify:action-pin-fixture && pnpm verify:action-pin-attestation-fixture && pnpm android:doctor",
    "android:doctor": "node scripts/android-verification.mjs doctor",
    "android:codegen": "node scripts/android-verification.mjs codegen",
    "android:build": "node scripts/android-verification.mjs build",
    "docker:android:build": "node scripts/docker-android.mjs build",
    "docker:android:verify": "node scripts/docker-android.mjs verify",
    "docker:android:example:typecheck": "node scripts/docker-android.mjs example:typecheck",
    "docker:android:example:codegen": "node scripts/docker-android.mjs example:codegen",
    "docker:android:example:android-unit-test": "node scripts/docker-android.mjs example:android-unit-test",
    "docker:android:example:build": "node scripts/docker-android.mjs example:build",
    "docker:android:ci": "node scripts/docker-android.mjs ci",
    "docker:android:shell": "node scripts/docker-android.mjs shell",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "keywords": [
    "react-native",
    "image",
    "image-processing",
    "compression",
    "resize",
    "transcode",
    "jpeg",
    "png",
    "webp",
    "heic",
    "heif",
    "avif"
  ],
  "peerDependencies": {
    "react-native": ">=0.73 <1.0"
  },
  "codegenConfig": {
    "name": "RNImageCompressionKitSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "outputDir": {
      "ios": "ios/generated",
      "android": "android/generated"
    },
    "android": {
      "javaPackageName": "com.imagecompressionkit"
    },
    "ios": {
      "modulesProvider": {
        "ImageCompressionKit": "RCTImageCompressionKit"
      }
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@vitest/coverage-v8": "4.1.10",
    "chrome-launcher": "1.2.1",
    "lighthouse": "13.4.0",
    "playwright-core": "1.61.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitepress": "1.6.4",
    "vitest": "4.1.10",
    "vue": "3.5.40"
  },
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=18"
  }
}
